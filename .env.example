# Server
HOST=0.0.0.0
PORT=3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fresh_donate
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis

# Admin Panel Credentials
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-in-production

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# Payment
# URL where the buyer is redirected after payment (your shop frontend)
PAYMENT_RETURN_URL=https://localhost:3002
# Public base URL of this backend for webhook callbacks
WEBHOOK_BASE_URL=http://localhost:3001

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Docker Compose
SERVER_PORT=3001
